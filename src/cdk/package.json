{
  "name": "it-english-trainee-cdk",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "cdk": "cdk",
    "synth:dev": "cdk synth --context env=dev",
    "synth:stg": "cdk synth --context env=stg",
    "synth:prod": "cdk synth --context env=prod",
    "deploy:dev": "cdk deploy --all --context env=dev --require-approval never",
    "deploy:stg": "cdk deploy --all --context env=stg --require-approval broadening",
    "deploy:prod": "cdk deploy --all --context env=prod --require-approval any-change",
    "diff:dev": "cdk diff --all --context env=dev",
    "diff:stg": "cdk diff --all --context env=stg",
    "diff:prod": "cdk diff --all --context env=prod",



    "lint": "eslint bin lib --ext .ts --max-warnings 0",
    "format": "prettier --write \"bin/**/*.ts\" \"lib/**/*.ts\"",
    "format:check": "prettier --check \"bin/**/*.ts\" \"lib/**/*.ts\""
  },
  "dependencies": {
    "aws-cdk-lib": "^2.130.0",
    "constructs": "^10.3.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "aws-cdk": "^2.130.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  }
}
